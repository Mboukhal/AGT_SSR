---
import Root from "../layouts/root.astro";
import "../styles/global.css";
import If from "../components/auth/if.svelte";
import Else from "../components/auth/else.svelte";

const Condition = "development";
---

<Root>
	<main class="min-h-screen flex items-center justify-center">
		<h1 class="text-2xl font-bold text-center mb-8">
			{"{{.Name}}"}
			<If condition={Condition === "development"}>
				<span class="text-sm text-gray-500">(Development Mode)</span>
				<Else />
				<span class="text-sm text-gray-500">(Production Mode)</span>
			</If>
		</h1>
	</main>
</Root>
