APP_NAME=SV_GO_PG

APP_ENV=development

# server ------------------------------
SERVER_PORT=3000

# ui dev server -----------------------
# SvelteKit/Vite default is typically 5173; keep in sync with `bun run dev`.
APP_PORT=5173

APP_PORT=1337
SERVER_PORT=3000
APP_DOMAIN=http://localhost:${SERVER_PORT}


# database ----------------------------
# CONTAINER_NAME=sv-go-pg-db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=${APP_NAME}
POSTGRES_PORT=6000
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

PGADMIN_DEFAULT_EMAIL=lios80466@gmail.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=8080

# pgadmin auto server registration ---
# These values are used to generate /tmp/servers.json inside the pgAdmin container.
PGADMIN_SERVER_NAME=Auto
PGADMIN_SERVER_GROUP=Servers
PGADMIN_DB_HOST=db
PGADMIN_DB_PORT=5432
PGADMIN_DB_MAINTENANCE_DB=postgres
PGADMIN_DB_USERNAME=${POSTGRES_USER}
PGADMIN_DB_SSLMODE=prefer


# storage -----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:${MINIO_PORT}
MINIO_USE_SSL=false
